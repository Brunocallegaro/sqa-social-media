    "_postman_id": "sqa-social-media-api-tests",
    "name": "SQA Social Media - API Tests",
    "description": "Coleção de testes de API para o projeto SQA Social Media",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "testEmail",
      "value": "teste_newman@email.com"
    },
    {
      "key": "testPassword",
      "value": "Senha@Newman123"
    },
    {
      "key": "userId",
      "value": ""
