    {
      "name": "Posts",
      "item": [
        {
          "name": "GET /posts - deve retornar lista de posts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status deve ser 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Resposta deve conter array de posts', function() {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.posts).to.be.an('array');",
                  "  pm.expect(body.posts.length).to.be.greaterThan(0);",
                  "});",
                  "pm.test('Cada post deve ter campo reactions com likes e dislikes', function() {",
                  "  const body = pm.response.json();",
                  "  body.posts.forEach(function(post) {",
                  "    pm.expect(post).to.have.property('reactions');",
                  "    pm.expect(post.reactions).to.have.property('likes');",
                  "    pm.expect(post.reactions).to.have.property('dislikes');",
                  "    pm.expect(post.reactions.likes).to.be.a('number');",
                  "    pm.expect(post.reactions.dislikes).to.be.a('number');",
                  "  });",
                  "});",
                  "pm.test('Cada post deve ter campo liked', function() {",
                  "  const body = pm.response.json();",
                  "  body.posts.forEach(function(post) {",
                  "    pm.expect(post).to.have.property('liked');",
                  "  });",
                  "});",
                  "pm.test('Resposta deve ter campos de paginação', function() {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('total');",
                  "  pm.expect(body).to.have.property('skip');",
                  "  pm.expect(body).to.have.property('limit');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts?limit=5&skip=0",
              "host": ["{{baseUrl}}"],
              "path": ["posts"],
              "query": [
                { "key": "limit", "value": "5" },
                { "key": "skip", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "POST /posts/:id/like - deve fazer toggle de like",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status deve ser 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Resposta deve conter postId e liked', function() {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('postId');",
                  "  pm.expect(body).to.have.property('liked');",
                  "  pm.expect(body.liked).to.be.a('boolean');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/1/like?userId={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "1", "like"],
              "query": [{ "key": "userId", "value": "{{userId}}" }]
            }
          }
        },
        {
          "name": "GET /posts/liked - deve retornar posts curtidos do usuário",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status deve ser 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Resposta deve conter array de posts', function() {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.posts).to.be.an('array');",
                  "});",
                  "pm.test('Posts curtidos devem ter reactions', function() {",
                  "  const body = pm.response.json();",
                  "  body.posts.forEach(function(post) {",
                  "    pm.expect(post).to.have.property('reactions');",
                  "  });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/liked?userId={{userId}}&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "liked"],
              "query": [
                { "key": "userId", "value": "{{userId}}" },
                { "key": "limit", "value": "5" }
              ]
            }
          }
        }
      ]
    },
